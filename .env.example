# Copy to .env and adjust. Loaded by config/settings.py via python-dotenv.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (matches docker-compose.yml) ---
POSTGRES_DB=place_engine
POSTGRES_USER=place_engine
POSTGRES_PASSWORD=place_engine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
